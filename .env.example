# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inventory
POSTGRES_PORT=5432

# App
APP_ENV=development
DEBUG=true
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/inventory
CORS_ORIGINS=http://localhost:3000
LOW_STOCK_THRESHOLD=5

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
# =========================================================================
# Root .env — used by docker-compose for variable substitution.
# Copy to `.env` and fill in real values for local development.
# =========================================================================

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inventory
POSTGRES_PORT=5432

# --- Backend ---
APP_ENV=development
DEBUG=true
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000
LOW_STOCK_THRESHOLD=5

# --- Frontend ---
FRONTEND_PORT=3000
# The URL the *browser* uses to reach the API (e.g. for any client-side fetches).
# Server-side fetches inside the docker network always use http://backend:8000.
PUBLIC_API_BASE_URL=http://localhost:8000
