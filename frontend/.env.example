# URL the Next.js server uses when fetching from the FastAPI backend.
# Inside docker-compose, set this to http://backend:8000.
# In Vercel (prod), set to your Render/Railway/Fly URL.
API_BASE_URL=http://localhost:8000

# Optional: if the browser ever needs to call the API directly (it normally doesn't,
# since we use Server Components + Server Actions), set this to the same URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
